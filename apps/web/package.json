{
  "name": "@solid-imager/web",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "PORT=3001 bun x --bun vinxi dev",
    "build": "bun x --bun vinxi build",
    "start": "PORT=3001 bun x --bun vinxi start",
    "lint": "biome lint ./src",
    "format": "biome format --fix ./src",
    "check": "biome check --fix --unsafe ./src",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@orpc/client": "^1.13.2",
    "@orpc/solid-query": "^1.13.2",
    "@orpc/tanstack-query": "^1.13.2",
    "@orpc/zod": "^1.13.2",
    "@solid-imager/core": "workspace:*",
    "@solid-imager/server": "workspace:*",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.2.1",
    "@tanstack/solid-db": "^0.1.59",
    "@tanstack/solid-form": "^1.27.7",
    "@tanstack/solid-query": "^5.90.19",
    "@tanstack/solid-virtual": "^3.13.16",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "solid-js": "^1.9.10",
    "solid-toast": "^0.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vinxi": "^0.5.10",
    "vite-plugin-solid": "^2.11.10",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@orpc/contract": "^1.13.2",
    "@orpc/server": "^1.13.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.4",
    "@vitest/coverage-v8": "^1.6.0",
    "baseline-browser-mapping": "^2.9.11",
    "bun-types": "^1.3.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "elysia": "^1.4.21",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "5.4.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^1.6.0"
  }
}
