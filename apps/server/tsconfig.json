{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "noEmit": true,
    "types": ["vitest/globals"],
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./src/*"],
      "@solid-imager/ui/*": ["../../packages/ui/src/*"],
      "@solid-imager/application": ["../../packages/application/src"],
      "@solid-imager/application/*": ["../../packages/application/src/*"],
      "@/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src", "src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts"],
  "exclude": ["node_modules", ".vinxi", ".output", "dist"]
}
