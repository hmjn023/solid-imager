{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "types": ["vitest/globals"],
    "isolatedModules": true,
    "paths": {
	  "#route-tree": ["./src/routeTree.gen.ts"],
      "~/*": ["./src/*"],
      "@solid-imager/ui/*": ["../../packages/ui/src/*"],
      "@solid-imager/application": ["../../packages/application/src"],
      "@solid-imager/application/*": ["../../packages/application/src/*"],
      "@/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src", "src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts"],
  "exclude": ["node_modules", ".vinxi", ".output", "dist"]
}
