{
	"name": "@solid-imager/server",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"start": "bun run db:migrate:pglite && bun .output/server/index.mjs",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:pglite": "bun scripts/migrate-pglite.ts",
		"db:push": "drizzle-kit push",
		"db:drop": "drizzle-kit drop",
		"db:dump": "bun scripts/dump-db.ts",
		"db:restore": "bun scripts/restore-db.ts",
		"db:studio": "drizzle-kit studio",
		"lint": "biome lint ./src",
		"format": "biome format --fix ./src",
		"check": "biome check --fix --unsafe ./src",
		"test": "bun run test:unit && bun run test:integration",
		"test:unit": "vp test run -c vitest.unit.config.ts",
		"test:integration": "vp test run -c vitest.integration.config.ts",
		"test:e2e": "playwright test",
		"typecheck": "sh -c 'tsc --noEmit --project ./tsconfig.json'",
		"gen:spec": "bun scripts/generate-swagger-spec.ts",
		"docs:generate": "typedoc"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.3.16",
		"@orpc/client": "^1.13.13",
		"@orpc/contract": "^1.13.13",
		"@orpc/experimental-pino": "^1.13.13",
		"@orpc/server": "^1.13.13",
		"@orpc/solid-query": "^1.13.13",
		"@orpc/tanstack-query": "^1.13.13",
		"@orpc/zod": "^1.13.13",
		"@solid-imager/application": "workspace:*",
		"@solid-imager/core": "workspace:*",
		"@solid-imager/db": "workspace:*",
		"@solid-imager/ui": "workspace:*",
		"@tanstack/router-plugin": "latest",
		"@tanstack/solid-form": "latest",
		"@tanstack/solid-query": "latest",
		"@tanstack/solid-router": "latest",
		"@tanstack/solid-router-devtools": "latest",
		"@tanstack/solid-router-ssr-query": "latest",
		"@tanstack/solid-start": "latest",
		"@tanstack/zod-form-adapter": "^0.42.1",
		"archiver": "^7.0.1",
		"chokidar": "^4.0.3",
		"drizzle-orm": "^0.44.7",
		"ffmpeg-static": "^5.3.0",
		"fluent-ffmpeg": "^2.1.3",
		"nitro": "npm:nitro-nightly@latest",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"sharp": "^0.34.5",
		"solid-js": "^1.9.12",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-dist": "^5.32.1",
		"uuid": "^13.0.0",
		"vite-tsconfig-paths": "^5.1.4",
		"yauzl": "^3.2.1",
		"youtube-dl-exec": "^3.1.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@orpc/openapi": "^1.13.13",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/devtools-vite": "latest",
		"@types/archiver": "^7.0.0",
		"@types/ffmpeg-static": "^5.1.0",
		"@types/fluent-ffmpeg": "^2.1.28",
		"@types/node": "^24.12.0",
		"@types/pg": "^8.20.0",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-dist": "^3.30.6",
		"@types/yauzl": "^2.10.3",
		"@vitest/coverage-v8": "^1.6.1",
		"baseline-browser-mapping": "^2.10.12",
		"bun-types": "^1.3.11",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.18",
		"typescript": "^5.9.3",
		"ultracite": "5.4.4",
		"vite": "^8.0.0",
		"vite-plugin-solid": "^2.11.11",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	}
}
