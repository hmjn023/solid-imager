{
  "name": "@solid-imager/server",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "start": "bun run db:migrate:pglite && bun .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:pglite": "bun scripts/migrate-pglite.ts",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:dump": "bun scripts/dump-db.ts",
    "db:restore": "bun scripts/restore-db.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint ./src",
    "format": "biome format --fix ./src",
    "check": "biome check --fix --unsafe ./src",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vp test run -c vitest.unit.config.ts",
    "test:integration": "vp test run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "gen:spec": "bun scripts/generate-swagger-spec.ts",
    "docs:generate": "typedoc"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@orpc/client": "^1.13.2",
    "@orpc/contract": "^1.13.2",
    "@orpc/experimental-pino": "^1.13.2",
    "@orpc/server": "^1.13.2",
    "@orpc/solid-query": "^1.13.2",
    "@orpc/tanstack-query": "^1.13.2",
    "@orpc/zod": "^1.13.2",
    "@solid-imager/core": "workspace:*",
    "@solid-imager/ui": "workspace:*",
    "@tanstack/router-plugin": "latest",
    "@tanstack/solid-form": "latest",
    "@tanstack/solid-query": "latest",
    "@tanstack/solid-router": "latest",
    "@tanstack/solid-router-devtools": "latest",
    "@tanstack/solid-router-ssr-query": "latest",
    "@tanstack/solid-start": "latest",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "drizzle-orm": "^0.44.7",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.12",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-dist": "^5.31.0",
    "uuid": "^13.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "yauzl": "^3.2.0",
    "youtube-dl-exec": "^3.0.30",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@orpc/openapi": "^1.13.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "latest",
    "@types/archiver": "^7.0.0",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^1.6.0",
    "baseline-browser-mapping": "^2.9.11",
    "bun-types": "^1.3.6",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "ultracite": "5.4.4",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
