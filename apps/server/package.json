{
  "name": "@solid-imager/server",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./api-contract": "./src/domain/shared/api-contract.ts"
  },
  "scripts": {
    "dev": "bun --bun run vp dev",
    "build": "bun --bun run vp build",
    "preview": "bun --bun run vp preview",
    "start": "bun --bun .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:pglite": "bun scripts/migrate-pglite.ts",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:dump": "bun scripts/dump-db.ts",
    "db:restore": "bun scripts/restore-db.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint ./src",
    "format": "biome format --fix ./src",
    "check": "biome check --fix --unsafe ./src",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vp test run -c vitest.unit.config.ts",
    "test:integration": "vp test run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "sh -c 'tsc --noEmit --project ./tsconfig.json'",
    "gen:spec": "bun scripts/generate-swagger-spec.ts",
    "docs:generate": "typedoc"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@lancedb/lancedb": "^0.30.0",
    "@orpc/client": "^1.14.4",
    "@orpc/contract": "^1.14.4",
    "@orpc/experimental-pino": "^1.14.4",
    "@orpc/server": "^1.14.4",
    "@orpc/solid-query": "^1.14.4",
    "@orpc/tanstack-query": "^1.14.4",
    "@orpc/zod": "^1.14.4",
    "@solid-imager/application": "workspace:*",
    "@solid-imager/client": "workspace:*",
    "@solid-imager/core": "workspace:*",
    "@solid-imager/db": "workspace:*",
    "@solid-imager/ui": "workspace:*",
    "@tanstack/router-plugin": "^1.168.14",
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-query": "5.101.0",
    "@tanstack/solid-router": "^1.170.11",
    "@tanstack/solid-router-devtools": "^1.167.0",
    "@tanstack/solid-router-ssr-query": "^1.167.1",
    "@tanstack/solid-start": "^1.168.19",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "apache-arrow": "^21.1.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "dghs-imgutils-rs": "github:hmjn023/dghs-imgutils-rs#main",
    "drizzle-orm": "^0.45.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "nitro": "npm:nitro-nightly@3.0.1-20260601-173724-a2597363",
    "pino": "^10.3.1",
    "sharp": "^0.35.1",
    "solid-js": "^1.9.13",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-dist": "^5.32.6",
    "uuid": "^14.0.0",
    "yauzl": "^3.3.2",
    "youtube-dl-exec": "^3.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@orpc/openapi": "^1.14.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@types/archiver": "^8.0.0",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/yauzl": "^3.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "baseline-browser-mapping": "^2.10.33",
    "bun-types": "^1.3.14",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vite": "^0.1.24",
    "vite-plugin-solid": "^2.11.12",
    "vite-plus": "^0.2.1",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.24"
  }
}
