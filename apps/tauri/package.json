{
	"name": "@solid-imager/tauri",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run tauri:dev",
		"build": "bun run tauri:build",
		"dev:web": "vp dev --host 0.0.0.0 --port 1420",
		"build:web": "vp build",
		"preview": "vp preview",
		"tauri:dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 bun x tauri dev",
		"tauri:build": "bun run build:web",
		"lint": "biome lint ./src",
		"format": "biome format --fix ./src",
		"check": "biome check --fix --unsafe ./src",
		"typecheck": "sh -c 'tsc --noEmit --project ./tsconfig.json'"
	},
	"dependencies": {
		"@orpc/client": "^1.14.4",
		"@orpc/solid-query": "^1.14.4",
		"@solid-imager/client": "workspace:*",
		"@solid-imager/core": "workspace:*",
		"@solid-imager/ui": "workspace:*",
		"@tanstack/db": "^0.6.8",
		"@tanstack/query-db-collection": "^1.0.40",
		"@tanstack/solid-db": "^0.2.22",
		"@tanstack/solid-query": "5.99.2",
		"@tanstack/solid-router": "latest",
		"@tanstack/tauri-db-sqlite-persistence": "^0.2.0",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-http": "^2.5.9",
		"@tauri-apps/plugin-sql": "^2.4.0",
		"solid-js": "^1.9.13",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tauri-apps/cli": "^2.11.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/router-plugin": "latest",
		"@types/node": "^26.0.0",
		"tailwindcss": "^4.3.0",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^6.0.3",
		"vite-plugin-solid": "^2.11.12",
		"vite-plus": "^0.1.24"
	}
}
