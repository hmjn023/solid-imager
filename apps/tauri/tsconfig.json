{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"noEmit": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"],
			"@solid-imager/core": ["../../packages/core/src"],
			"@solid-imager/core/*": ["../../packages/core/src/*"],
			"@solid-imager/client": ["../../packages/client/src"],
			"@solid-imager/client/*": ["../../packages/client/src/*"],
			"@solid-imager/ui/*": ["../../packages/ui/src/*"],
			"@/*": ["../../packages/core/src/*"]
		}
	},
	"include": ["src", "src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist", ".vinxi", ".output", "src-tauri"]
}
