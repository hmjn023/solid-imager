{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@solid-imager/core": ["./packages/core/src"],
      "@solid-imager/core/*": ["./packages/core/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".vinxi", ".output"]
}
