{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "types": [
      "vinxi/types/client",
      "vitest/globals"
    ],
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./src/*"
      ]
    },
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "exclude": [
    "xtracter",
    "node_modules",
    ".vinxi",
    ".output",
    "dist",
    "scripts"
  ]
}