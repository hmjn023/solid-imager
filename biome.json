{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useNamingConvention": "off"
			},
			"performance": {
				"noBarrelFile": "off"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noDeprecatedImports": "error"
			}
		}
	},
	"files": {
		"includes": [
			"apps/**/src/**",
			"packages/**/src/**",
			"!**/node_modules",
			"!**/dist",
			"!**/.vinxi",
			"!**/.output",
			"!**/db-data",
			"!**/.worktree",
			"!apps/server/src/app.css",
			"!apps/server/public/docs",
			"!apps/server/scripts",
			"!apps/server/playwright.config.ts",
			"!apps/server/get-media-ids.ts"
		]
	},
	"overrides": [
		{
			"includes": ["src/db/schema.ts"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/xtracter/src/**/*.ts", "apps/xtracter/src/**/*.tsx"],
			"javascript": {
				"globals": ["chrome", "window", "document", "navigator", "console"]
			}
		},
		{
			"includes": ["**/routeTree.gen.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/tests/**/*.ts",
				"**/tests/**/*.tsx"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
