{
  "name": "example-with-tailwindcss",
  "type": "module",
  "workspaces": [
    "xtracter"
  ],
  "scripts": {
    "dev": "bun run vinxi dev",
    "build": "bun --bun run vinxi build",
    "start": "bun --bun run vinxi start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:pglite": "bun scripts/migrate-pglite.ts",
    "ai:start": "uv run uvicorn src-python.main:app --reload --host 0.0.0.0 --port 8000",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:dump": "bun scripts/dump-db.ts",
    "db:restore": "bun scripts/restore-db.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint ./src",
    "format": "biome format --fix ./src",
    "check": "biome check --fix --unsafe ./src",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "gen:spec": "bun scripts/generate-swagger-spec.ts",
    "docs:generate": "typedoc",
    "unsafe-fix": "biome check --fix --unsafe ./src",
    "prepare": "husky"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@elysiajs/swagger": "^1.3.1",
    "@kobalte/core": "^0.13.11",
    "@orpc/client": "^1.13.2",
    "@orpc/contract": "^1.13.2",
    "@orpc/experimental-pino": "^1.13.2",
    "@orpc/server": "^1.13.2",
    "@orpc/solid-query": "^1.13.2",
    "@orpc/tanstack-query": "^1.13.2",
    "@orpc/zod": "^1.13.2",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.2.1",
    "@tanstack/solid-db": "^0.1.59",
    "@tanstack/solid-form": "^1.27.7",
    "@tanstack/solid-query": "^5.90.19",
    "@tanstack/solid-virtual": "^3.13.16",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "drizzle-orm": "^0.44.7",
    "elysia": "^1.4.21",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.10",
    "solid-toast": "^0.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-dist": "^5.31.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "vinxi": "^0.5.10",
    "vite-plugin-solid": "^2.11.10",
    "youtube-dl-exec": "^3.0.30",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@orpc/openapi": "^1.13.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/archiver": "^7.0.0",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/unzipper": "^0.10.11",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.11",
    "bun-types": "^1.3.6",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "ultracite": "5.4.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "biome check --fix --unsafe"
    ],
    "src/tests/**/*.{ts,tsx}": [
      "vitest related --run"
    ],
    "src/!(tests)/**/*.{ts,tsx}": [
      "vitest related --run",
      "vinxi build"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'bun run typecheck'"
    ]
  },
  "resolutions": {
    "vite": "^5.4.0"
  },
  "trustedDependencies": [
    "youtube-dl-exec",
    "ffmpeg-static"
  ]
}