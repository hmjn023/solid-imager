{
  "name": "solid-imager-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "xtracter"
  ],
  "scripts": {
    "dev:server": "bun --filter @solid-imager/server dev",
    "dev:web": "bun --filter @solid-imager/web dev",
    "dev": "bun run dev:server & bun run dev:web",
    "build": "bun --filter '*' build",
    "start:server": "bun --filter @solid-imager/server start",
    "start:web": "bun --filter @solid-imager/web start",
    "start": "bun run start:server & bun run start:web",
    "ai:start": "uv run uvicorn src-python.main:app --host 0.0.0.0 --port 8000",
    "lint": "bun x biome lint .",
    "check": "bun x biome check --fix --unsafe .",
    "format": "bun x biome format --fix .",
    "test": "bun --filter @solid-imager/server test",
    "typecheck": "bun --filter '*' typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/server/src/**/*.{ts,tsx,js,jsx,json}": [
      "bun --filter @solid-imager/server lint",
      "bun --filter @solid-imager/server check",
      "bun --filter @solid-imager/server test:unit"
    ],
    "apps/web/src/**/*.{ts,tsx,js,jsx,json}": [
      "bun --filter @solid-imager/web lint",
      "bun --filter @solid-imager/web check"
    ],
    "packages/core/src/**/*.{ts,tsx,js,jsx,json}": [
      "bun --filter @solid-imager/core lint"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'bun run typecheck'"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "youtube-dl-exec",
    "ffmpeg-static"
  ]
}
