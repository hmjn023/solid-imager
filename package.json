{
  "name": "example-with-tailwindcss",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:pglite": "bun scripts/migrate-pglite.ts",
    "ai:start": "uv run uvicorn python-src.main:app --reload --port 8000",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint ./src",
    "format": "biome format --fix ./src",
    "check": "biome check --fix --unsafe ./src",
    "test": "vitest run",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "gen:spec": "bun scripts/generate-swagger-spec.ts",
    "docs:generate": "typedoc",
    "unsafe-fix": "biome check --fix --unsafe ./src",
    "prepare": "husky"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@kobalte/core": "^0.13.11",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.2.0",
    "@tanstack/solid-db": "^0.1.48",
    "@tanstack/solid-form": "^1.26.0",
    "@tanstack/solid-query": "^5.90.13",
    "@tanstack/solid-virtual": "^3.13.13",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "drizzle-orm": "^0.44.7",
    "fluent-ffmpeg": "^2.1.3",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.10",
    "solid-toast": "^0.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-dist": "^5.30.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "vinxi": "^0.5.8",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/archiver": "^7.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/ssh2-sftp-client": "^9.0.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/unzipper": "^0.10.11",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.11",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "ultracite": "5.4.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "biome check --fix --unsafe"
    ],
    "src/tests/**/*.{ts,tsx}": [
      "vitest related --run"
    ],
    "src/!(tests)/**/*.{ts,tsx}": [
      "vitest related --run",
      "vinxi build"
    ]
  }
}
