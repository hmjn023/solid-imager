{
  "name": "solid-imager-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "xtracter"
  ],
  "scripts": {
    "dev": "bun --filter @solid-imager/server dev",
    "build": "bun --filter @solid-imager/server build",
    "start": "bun --filter @solid-imager/server start",
    "lint": "bun x biome lint .",
    "format": "bun x biome format --fix .",
    "test": "bun --filter @solid-imager/server test",
    "typecheck": "bun --filter '*' typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/server/src/**/*.{ts,tsx,js,jsx,json}": [
      "bun --filter @solid-imager/server lint",
      "bun --filter @solid-imager/server check"
    ],
    "packages/core/src/**/*.{ts,tsx,js,jsx,json}": [
      "bun --filter @solid-imager/core lint"
    ],
    "**/*.{ts,tsx}": [
      "bun run typecheck"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "youtube-dl-exec",
    "ffmpeg-static"
  ]
}
