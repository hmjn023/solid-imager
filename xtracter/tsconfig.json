{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "paths": {
            "~/domain/shared/api-contract": [
                "../apps/server/src/domain/shared/api-contract"
            ],
            "~/domain/*": [
                "../packages/core/src/domain/*"
            ],
            "~/*": [
                "../apps/server/src/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}
