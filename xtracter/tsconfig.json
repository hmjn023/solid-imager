{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@ext/*": [
        "./src/*"
      ],
      "~/*": [
        "../apps/server/src/*"
      ],
      "@/*": [
        "../packages/core/src/*"
      ],
      "@solid-imager/core/*": [
        "../packages/core/src/*"
      ],
      "@solid-imager/server/*": [
        "../apps/server/src/*"
      ],
      "@core/*": [
        "../packages/core/src/*"
      ],
      "@server/*": [
        "../apps/server/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}