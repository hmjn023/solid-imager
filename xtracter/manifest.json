{
  "manifest_version": 3,
  "name": "xtracter",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://video.twimg.com/*",
    "https://danbooru.donmai.us/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "http://*/*"
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://danbooru.donmai.us/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  }
}
