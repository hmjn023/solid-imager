{
  "name": "@solid-imager/db",
  "version": "0.0.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./types": "./src/types.ts",
    "./transaction-manager": "./src/transaction-manager.ts",
    "./errors": "./src/errors.ts",
