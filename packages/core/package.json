{
	"name": "@solid-imager/core",
	"version": "0.0.0",
	"description": "Core business logic and interfaces for Solid Imager",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./domain/errors": "./src/domain/errors/index.ts",
		"./domain/*/schemas": "./src/domain/*/schemas.ts",
		"./domain/repositories/*": "./src/domain/repositories/*.ts",
		"./domain/services/*": "./src/domain/services/*.ts",
		"./domain/interfaces/*": "./src/domain/interfaces/*.ts",
		"./domain/search/*": "./src/domain/search/*.ts",
		"./domain/sources/*": "./src/domain/sources/*.ts",
		"./domain/tagging/*": "./src/domain/tagging/*.ts",
		"./domain/tags/*": "./src/domain/tags/*.ts",
		"./domain/media/*": "./src/domain/media/*.ts",
		"./domain/media/utils/*": "./src/domain/media/utils/*.ts",
		"./domain/shared/*": "./src/domain/shared/*.ts",
		"./domain/config/*": "./src/domain/config/*.ts",
		"./interfaces/*": "./src/interfaces/*.ts",
		"./utils/deep-equal": "./src/utils/deep-equal.ts",
		"./utils/event-parsers": "./src/utils/event-parsers.ts"
	},
	"scripts": {
		"check": "biome check --fix --unsafe ./src",
		"typecheck": "sh -c 'tsc --noEmit'",
		"lint": "biome lint ./src",
		"test": "vp test run",
		"test:unit": "vp test run"
	},
	"devDependencies": {
		"@types/node": "^24.10.4",
		"typescript": "^5.9.3",
		"vite-plus": "latest",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	},
	"peerDependencies": {
		"solid-js": "^1.9.12",
		"zod": "^4.3.5"
	}
}
