{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"@/*": ["../core/src/*"],
			"@solid-imager/core": ["../core/src/index.ts"],
			"@solid-imager/core/*": ["../core/src/*"],
			"@solid-imager/db": ["../db/src/index.ts"],
			"@solid-imager/db/*": ["../db/src/*"]
		}
	},
	"include": ["src"]
}
