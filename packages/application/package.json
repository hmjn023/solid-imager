{
  "name": "@solid-imager/application",
  "version": "0.0.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./services/*": "./src/services/*.ts",
    "./ports/*": "./src/ports/*.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "check": "biome check --fix --unsafe ./src",
    "typecheck": "sh -c 'tsc --noEmit'",
    "lint": "biome lint ./src",
    "test": "vp test run",
    "test:unit": "vp test run"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@solid-imager/core": "workspace:*",
    "apache-arrow": "^21.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.24"
  }
}
