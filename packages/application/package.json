{
	"name": "@solid-imager/application",
	"version": "0.0.0",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./services/*": "./src/services/*.ts",
		"./utils/*": "./src/utils/*.ts",
		"./ports/*": "./src/ports/*.ts"
	},
	"scripts": {
		"check": "biome check --fix --unsafe ./src",
		"typecheck": "sh -c 'tsc --noEmit'",
		"lint": "biome lint ./src",
		"test": "vp test run",
		"test:unit": "vp test run"
	},
	"dependencies": {
		"@solid-imager/core": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.9.3",
		"vite-plus": "latest",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	}
}
