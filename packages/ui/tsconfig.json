{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"],
			"@/*": ["../core/src/*"],
			"@solid-imager/core": ["../core/src/index.ts"],
			"@solid-imager/core/*": ["../core/src/*"]
		}
	},
	"include": ["src/**/*"]
}
