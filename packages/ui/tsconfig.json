{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*"]
}
